# ByteSiren Worker local environment example.
# Copy to apps/worker/.dev.vars for local development.
# Never commit apps/worker/.dev.vars or real tokens.

# Claude / Web Search. Leave ANTHROPIC_API_KEY blank unless you are explicitly
# validating Claude locally.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_WEB_SEARCH_TOOL_TYPE=web_search_20260209
CLAUDE_DEFAULT_MAX_USES=2
CLAUDE_SECOND_SEARCH_MAX_USES=3
CLAUDE_PUBLIC_DAILY_ANALYSIS_LIMIT=5
# Optional request timeout for live Claude calls. GitHub v0.2 enrichment uses
# 600000 so a single Claude request can run up to 10 minutes before aborting.
CLAUDE_REQUEST_TIMEOUT_MS=120000
CLAUDE_ALLOWED_DOMAINS=
CLAUDE_BLOCKED_DOMAINS=coindcx.com,bitcoinfoundation.org,tradingkey.com,intellectia.ai,mexc.com,bitget.com,stealthex.io

# Public API CORS origins. Add the deployed Pages origin before production use.
PUBLIC_WEB_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,https://bytesiren.pages.dev

# v0.2 integration flags. Production now serves the v0.2 public feed by default
# from tracked wrangler.toml. Keep FEED_VERSION=v01 here only for local fallback
# or legacy-feed testing unless you are validating local v0.2 rows.
DETECTOR_VERSION=v01
FEED_VERSION=v01
ENABLE_MARKET_STORIES=false
ENABLE_DAILY_OVERVIEWS=false
ENABLE_SIGNAL_CLAUDE_V02=false
ENABLE_DAILY_CLAUDE=false
CLAUDE_CATCHUP_LIMIT=5
ENABLE_SCHEDULED_JOBS=true

# Protected admin/local tooling. Keep disabled unless running controlled local smoke.
ENABLE_ADMIN_MAINTENANCE=false
ENABLE_V02_ADMIN_TOOLS=false
ENABLE_V02_CLAUDE_SAMPLE_TOOLS=false
ENABLE_V02_REFRESH_WORKFLOW_DISPATCH=false
ENABLE_V02_INCREMENTAL_REFRESH=false
ENABLE_V02_INCREMENTAL_SIGNALS=true
ENABLE_V02_INCREMENTAL_MARKET_STORIES=true
ENABLE_V02_INCREMENTAL_DAILY_OVERVIEWS=false
V02_INCREMENTAL_LOOKBACK_HOURS=24
V02_INCREMENTAL_TARGET_WINDOW_HOURS=6
V02_DAILY_OVERVIEW_LOOKBACK_DAYS=5
V02_MARKET_STORY_OPEN_TTL_HOURS=72
V02_INCREMENTAL_MAX_SIGNALS_PER_RUN=25
ENABLE_V02_SIGNAL_CLAUDE_WORKFLOW_DISPATCH=false
V02_CLAUDE_WORKFLOW_FILE=v02-claude-enrichment.yml
V02_CLAUDE_WORKFLOW_REF=main
V02_CLAUDE_SIGNAL_DISPATCH_LIMIT=3
V02_CLAUDE_DISPATCH_COOLDOWN_MIN=15
V02_SIGNAL_CLAUDE_WORKFLOW_FILE=v02-claude-enrichment.yml
V02_SIGNAL_CLAUDE_WORKFLOW_REF=main
V02_SIGNAL_CLAUDE_DISPATCH_LIMIT=3
ADMIN_BACKFILL_TOKEN=

# Local v0.2 smoke profile, using throwaway local tokens:
# DETECTOR_VERSION=v02
# FEED_VERSION=v02
# ENABLE_MARKET_STORIES=true
# ENABLE_DAILY_OVERVIEWS=true
# ENABLE_MARKET_IMPORT=true
# ENABLE_ADMIN_MAINTENANCE=true
# ENABLE_V02_ADMIN_TOOLS=true
# ENABLE_V02_CLAUDE_SAMPLE_TOOLS=false
# ENABLE_SIGNAL_CLAUDE_V02=false
# ENABLE_DAILY_CLAUDE=false
# ENABLE_SCHEDULED_JOBS=false
# MARKET_IMPORT_TOKEN=<local token>
# ADMIN_BACKFILL_TOKEN=<local token>

# Controlled v0.2 Claude sample profile:
# ENABLE_ADMIN_MAINTENANCE=true
# ENABLE_V02_ADMIN_TOOLS=true
# ENABLE_V02_CLAUDE_SAMPLE_TOOLS=true
# ENABLE_SIGNAL_CLAUDE_V02=false
# ENABLE_DAILY_CLAUDE=false
# CLAUDE_CATCHUP_LIMIT=1

# Protected market import. Production uses GitHub Actions -> Worker import.
ENABLE_MARKET_IMPORT=true
MARKET_IMPORT_TOKEN=
MARKET_FETCH_MODE=external_import

# GitHub ingestion dispatch. Token must be a Worker secret in production.
ENABLE_GITHUB_INGEST_DISPATCH=true
GITHUB_INGEST_OWNER=Sorbemelon
GITHUB_INGEST_REPO=ByteSiren
GITHUB_INGEST_WORKFLOW=market-ingest.yml
GITHUB_INGEST_REF=main
GITHUB_INGEST_HOURS=6
GITHUB_INGEST_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT
GITHUB_INGEST_DRY_RUN=false
GITHUB_INGEST_DISPATCH_TOKEN=

# v0.2 deterministic snapshot refresh dispatch is manual/backstop only.
# Do not enable ENABLE_V02_REFRESH_WORKFLOW_DISPATCH for normal cron refresh.
GITHUB_REFRESH_WORKFLOW_REPO=Sorbemelon/ByteSiren
GITHUB_REFRESH_WORKFLOW_FILE=v02-snapshot-refresh.yml
GITHUB_REFRESH_WORKFLOW_REF=main
