# ByteSiren Worker local environment example
# Copy this file to apps/worker/.dev.vars for local development.
# Never commit apps/worker/.dev.vars.

ANTHROPIC_API_KEY=

# Claude model for market-intelligence briefs.
# Current balanced default on the Claude API.
CLAUDE_MODEL=claude-sonnet-4-6

# Use the basic Web Search tool for Phase 4B.
# The newer web_search_20260209 is for dynamic filtering and requires code execution support,
# so keep Phase 4B simpler with web_search_20250305 first.
CLAUDE_WEB_SEARCH_TOOL_TYPE=web_search_20250305

# Default one search per qualifying incident.
CLAUDE_DEFAULT_MAX_USES=1

# Allow a second search only for strict fallback cases:
# none_found, context_only without focused cause, rejected-only first result,
# severity 100 + breadth 5, or two-sided market_day.
CLAUDE_SECOND_SEARCH_MAX_USES=2

# Conservative free-public-demo daily cap.
# Increase to 8 later if too many visible incidents remain queued/limited.
CLAUDE_PUBLIC_DAILY_ANALYSIS_LIMIT=5

# Optional allow-list. Leave blank for local smoke because some reputable
# domains may block Anthropic's web-search crawler and cause request rejection.
CLAUDE_ALLOWED_DOMAINS=

# Use blocked domains by default for local smoke.
# Claude Web Search supports either allowed_domains or blocked_domains, not both.
CLAUDE_BLOCKED_DOMAINS=coindcx.com,bitcoinfoundation.org,tradingkey.com,intellectia.ai,mexc.com,bitget.com,stealthex.io

# Comma-separated frontend origins allowed to call public Worker API routes.
# Keep local dev origins and add the deployed Cloudflare Pages origin before deploy.
PUBLIC_WEB_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,https://bytesiren.pages.dev

# Protected maintenance diagnostics. Keep disabled except during controlled maintenance.
# ADMIN_BACKFILL_TOKEN must be set as a Worker secret in production.
ENABLE_ADMIN_MAINTENANCE=false
ADMIN_BACKFILL_TOKEN=

# Protected external market import endpoint for GitHub Actions ingestion.
# MARKET_IMPORT_TOKEN must be set as a Worker secret in production.
ENABLE_MARKET_IMPORT=true
MARKET_IMPORT_TOKEN=

# Production market ingestion uses external_import because Binance may block
# Cloudflare Worker egress. Use worker_fetch only for controlled local tests.
MARKET_FETCH_MODE=external_import
