    "tailwindcss": "^4.1.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint-config-next": "^15.3.4",
    "wrangler": "^4.20.5"
  }
